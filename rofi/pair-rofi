        -p "PAIRS ─── Reference" \
        -mesg "14 accounting relationships. Select for details. Ctrl+Enter: create entry." \
        
    )
    local exit_code=$?

    if [[ "$choice" == "Back" ]]; then
        screen_root
        return
    fi

    # Extract pair number
    local pair_num
    pair_num=$(echo "$choice" | awk '{print $1}')

    if [[ $exit_code -eq 10 ]]; then
