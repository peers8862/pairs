screen_asset_pick() {
    local action="$1"
    local csv
    csv=$(run_pair asset list --format csv 2>/dev/null | tail -n +2)

    if [[ -z "$csv" ]]; then
        rofi_message "No assets found."
        screen_assets
        return
    fi

    # Build display list from CSV: name,slug,category,cost,nbv,status
    local items=""
    while IFS=',' read -r name slug category cost nbv status; do
        items+="$slug    $name    NBV: \$$nbv"$'\n'
    done <<< "$csv"

    local choice
    choice=$(echo "$items" | rofi -dmenu -theme "$THEME" \
        -p "Select asset" \
        -mesg "Select an asset for: $action" \
    ) || screen_assets

    # Extract slug (first field)
    local slug
    slug=$(echo "$choice" | awk '{print $1}')

    if [[ "$action" == "show" ]]; then
        local output
        output=$(run_pair asset show "$slug" 2>/dev/null)
        log_recent "Asset: $slug"
        local next
        next=$(echo -e "Back\nShow schedule\nEdit\nDispose\nOpen in terminal" | \
            rofi -dmenu -theme "$THEME" -p "$slug" -mesg "$(truncate_output "$output")") || screen_assets
        case "$next" in
            "Back")             screen_assets ;;
            "Show schedule")    output=$(run_pair asset show "$slug" --schedule)
                                echo "Back" | rofi -dmenu -theme "$THEME" -p "$slug schedule" -mesg "$(truncate_output "$output")" || true
                                screen_assets ;;
            "Edit")             open_terminal asset edit "$slug" ;;
            "Dispose")          open_terminal asset dispose "$slug" ;;
            "Open in terminal") open_terminal asset show "$slug" ;;
        esac
    else
        open_terminal asset "$action" "$slug"
    fi
}

