#!/usr/bin/env bash
# pair-rofi — near-fullscreen accounting overlay
# Mainframe-aesthetic rofi interface for the pairs tool

set -euo pipefail

# ─── Config ──────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PAIR_DIR="$(dirname "$SCRIPT_DIR")"
PAIR_CMD="$PAIR_DIR/pair"
THEME="$SCRIPT_DIR/ledger.rasi"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pair-rofi"
RECENT_FILE="$CONFIG_DIR/recent"
BOOKMARKS_FILE="$CONFIG_DIR/bookmarks"
TERMINAL="${TERMINAL:-xterm -hold -e}"

mkdir -p "$CONFIG_DIR"
touch "$RECENT_FILE" "$BOOKMARKS_FILE"

# ─── Helpers ─────────────────────────────────────────────────────────────────

ENTITY=$(python3 "$PAIR_CMD" prompt 2>/dev/null | tr -d '[]' | tr -d ' ')

rofi_menu() {
    local prompt_text="$1"
    local mesg="$2"
    shift 2
    local items="$*"

    local rofi_args=(-dmenu -theme "$THEME" -p "$prompt_text")

    if [[ -n "$mesg" ]]; then
        rofi_args+=(-mesg "$mesg")
    fi

    echo "$items" | rofi "${rofi_args[@]}"
    return ${PIPESTATUS[1]:-$?}
}

rofi_prompt() {
    local prompt_text="$1"
    local mesg="${2:-}"
    local rofi_args=(-dmenu -theme "$THEME" -p "$prompt_text" -lines 0)
    if [[ -n "$mesg" ]]; then
        rofi_args+=(-mesg "$mesg")
    fi
    echo "" | rofi "${rofi_args[@]}"
}

rofi_message() {
    local mesg="$1"
    echo "" | rofi -dmenu -theme "$THEME" -p "" -mesg "$mesg" -lines 1 <<< "OK"
}

# Max lines for message area (keeps window on screen at 768px height)
MAX_MESG_LINES=14

truncate_output() {
    local input="$1"
    local lines
    lines=$(echo "$input" | wc -l)
    if [[ $lines -gt $MAX_MESG_LINES ]]; then
        echo "$input" | head -n $MAX_MESG_LINES
        echo "... ($((lines - MAX_MESG_LINES)) more lines — open in terminal for full view)"
    else
        echo "$input"
    fi
}

run_pair() {
    python3 "$PAIR_CMD" "$@" 2>/dev/null
}

open_terminal() {
    $TERMINAL python3 "$PAIR_CMD" "$@" &
}

log_recent() {
    local action="$1"
    # Prepend to recent file, keep last 5
    local tmp
    tmp=$(mktemp)
    echo "$action" > "$tmp"
    head -4 "$RECENT_FILE" >> "$tmp" 2>/dev/null
    mv "$tmp" "$RECENT_FILE"
}

calc() {
    python3 -c "from decimal import Decimal; print(round($1, 2))" 2>/dev/null
}

# ─── Screens ─────────────────────────────────────────────────────────────────

screen_root() {
    # Build menu items
    local items=""

    # Recent
    if [[ -s "$RECENT_FILE" ]]; then
        items+="── RECENT ──────────────────────────────"$'\n'
        while IFS= read -r line; do
            items+="  $line"$'\n'
        done < "$RECENT_FILE"
    fi

    items+="── ACTIONS ─────────────────────────────"$'\n'
    items+="  New Entry"$'\n'
    items+="  Quick Expense"$'\n'
    items+="  Quick Transfer"$'\n'
    items+="  Net Worth"$'\n'
    items+="── MODULES ─────────────────────────────"$'\n'
    items+="  Assets"$'\n'
    items+="  Liabilities"$'\n'
    items+="  Expenses"$'\n'
    items+="  Income"$'\n'
    items+="  Revenue"$'\n'
    items+="  Budget"$'\n'
    items+="── MANAGEMENT ──────────────────────────"$'\n'
    items+="  Contacts"$'\n'
    items+="  Contracts"$'\n'
    items+="  Payroll"$'\n'
    items+="  Tax"$'\n'
    items+="  Recurring"$'\n'
    items+="── SYSTEM ──────────────────────────────"$'\n'
    items+="  Pairs Reference"$'\n'
    items+="  Switch Entity [$ENTITY]"$'\n'
    items+="  Status"$'\n'
    items+="  Config"

    local choice
    choice=$(echo "$items" | rofi -dmenu -theme "$THEME" \
        -p "PAIRS ─── $ENTITY" \
        -mesg "Enter: select | Ctrl+X: quick expense | ?: help" \
        
        
    ) || return

    # Strip leading whitespace
    choice=$(echo "$choice" | sed 's/^[[:space:]]*//')

    case "$choice" in
        "New Entry")          screen_new_entry ;;
        "Quick Expense")      flow_quick_expense ;;
        "Quick Transfer")     flow_quick_transfer ;;
        "Net Worth")          screen_worth ;;
        "Assets")             screen_assets ;;
        "Liabilities")        screen_liabilities ;;
        "Expenses")           screen_expenses ;;
        "Income")             screen_income ;;
        "Revenue")            screen_revenue ;;
        "Budget")             screen_budget ;;
        "Contacts")           screen_contacts ;;
        "Contracts")          screen_contracts ;;
        "Payroll")            screen_payroll ;;
        "Tax")               screen_tax ;;
        "Recurring")          screen_recurring ;;
        "Pairs Reference")    screen_pairs ;;
        "Switch Entity"*)    screen_switch ;;
        "Status")             screen_status ;;
        "Config")             open_terminal config ;;
        ──*)                  screen_root ;;  # separator selected, re-show
        *)                    # Check if it's a recent action or calc
                              if [[ "$choice" == "="* ]]; then
                                  result=$(calc "${choice#=}")
                                  rofi_message "= $result"
                                  screen_root
                              fi ;;
    esac
}

