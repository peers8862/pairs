# ─── Quick Flows (rofi-native) ───────────────────────────────────────────────

flow_quick_expense() {
    local desc amount category expense_date

    desc=$(rofi_prompt "Description") || return
    [[ -z "$desc" ]] && return

    # Category selection
    local categories="office
software
professional
travel
meals
marketing
telecom
utilities
insurance
bank-fees
repairs
rent
other"
    category=$(echo "$categories" | rofi -dmenu -theme "$THEME" -p "Category") || return
    [[ -z "$category" ]] && return

    amount=$(rofi_prompt "Amount") || return
    [[ -z "$amount" ]] && return

    expense_date=$(rofi_prompt "Date [$(date +%Y-%m-%d)]") || return
    [[ -z "$expense_date" ]] && expense_date=$(date +%Y-%m-%d)

    # Execute
    run_pair expense add --batch --desc "$desc" --amount "$amount" --category "$category" --date "$expense_date" >/dev/null
    log_recent "Expense: $desc — \$$amount ($category)"
    rofi_message "✓ Recorded: $desc — \$$amount ($category)"
    screen_root
}

flow_quick_transfer() {
    local from_acct to_acct amount transfer_date

    # From account
    local accounts="Chequing
Savings
Petty Cash"
    from_acct=$(echo "$accounts" | rofi -dmenu -theme "$THEME" -p "From account") || return
    [[ -z "$from_acct" ]] && return

    to_acct=$(echo "$accounts" | rofi -dmenu -theme "$THEME" -p "To account") || return
    [[ -z "$to_acct" ]] && return

    amount=$(rofi_prompt "Amount") || return
    [[ -z "$amount" ]] && return

    transfer_date=$(rofi_prompt "Date [$(date +%Y-%m-%d)]") || return
    [[ -z "$transfer_date" ]] && transfer_date=$(date +%Y-%m-%d)

    # Map short names to full accounts
    local from_full="Assets:Current:$from_acct"
    local to_full="Assets:Current:$to_acct"

    open_terminal transfer --batch --from "$from_full" --to "$to_full" --amount "$amount" --date "$transfer_date"
    log_recent "Transfer: \$$amount $from_acct → $to_acct"
}

