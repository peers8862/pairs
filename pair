#!/usr/bin/env python3
"""pair - business accounting on hledger, organized by accounting pairs."""

import sys
import os

# Allow imports from lib/ and modules/
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, BASE_DIR)

from lib.helpers import load_config


# ─── Module dispatch ─────────────────────────────────────────────────────────

MODULE_MAP = {
    'asset': 'modules.asset',
    'liability': 'modules.liability',
    'worth': 'modules.worth',
    'expense': 'modules.expense',
    'revenue': 'modules.revenue',
    'contact': 'modules.contact',
    'contract': 'modules.contract',
    'payroll': 'modules.payroll',
    'equity': 'modules.equity',
    'tax': 'modules.tax',
    'recurring': 'modules.recurring',
    'budget': 'modules.budget',
    'income': 'modules.income',
    'transfer': 'modules.transfer',
    'division': 'modules.division',
}

CORE_COMMANDS = ['init', 'generate', 'worth', 'journal', 'year', 'status', 'where', 'pairs', 'config', 'entry']


def main():
    # If invoked as 'pairs' (symlink), show reference table
    invoked_as = os.path.basename(sys.argv[0])
    if invoked_as == 'pairs':
        from modules.pairs import cmd_pairs
        cmd_pairs(sys.argv[1:])
        return

    if len(sys.argv) < 2:
        # No args = launch interactive pair entry
        from modules.pairs import cmd_pair
        cmd_pair([])
        return

    command = sys.argv[1]

    # Help flag
    if command in ('--help', '-h', 'help'):
        print_usage()
        sys.exit(0)

    # Core commands (not module-based)
    if command == 'init':
        from modules.init import cmd_init
        cmd_init()
    elif command == 'generate':
        from modules.generate import cmd_generate
        cmd_generate(sys.argv[2:])
    elif command == 'journal':
        from modules.journal import cmd_journal
        cmd_journal(sys.argv[2:])
    elif command == 'year':
        from modules.year import cmd_year
        cmd_year(sys.argv[2:])
    elif command == 'status':
        from modules.status import cmd_status
        cmd_status(sys.argv[2:])
    elif command == 'where':
        from modules.where import cmd_where
        cmd_where(sys.argv[2:])
    # Worth is both a core command and a module
    elif command == 'worth':
        from modules.worth import dispatch
        dispatch(sys.argv[2:])
    # Pairs reference table
    elif command == 'pairs':
        from modules.pairs import cmd_pairs
        cmd_pairs(sys.argv[2:])
    # Explicit entry command (alias for no-arg behavior)
    elif command == 'entry':
        from modules.pairs import cmd_pair
        cmd_pair(sys.argv[2:])
    # Config
    elif command == 'config':
        from modules.config import cmd_config
        cmd_config(sys.argv[2:])
    # Module dispatch
    elif command in MODULE_MAP:
        module = __import__(MODULE_MAP[command], fromlist=['dispatch'])
        module.dispatch(sys.argv[2:])
    else:
        print(f"Unknown command: {command}")
        print("Run 'pair --help' for usage.")
        sys.exit(1)


def print_usage():
    print("""pair — business accounting on hledger

  pair                      Interactive entry from any accounting pair
  pair --help               This help

Core commands:
  init                      First-time setup
  config                    View/edit configuration
  generate                  Regenerate journals from YAML
  worth                     Net worth report
  journal                   Synthesized journal for any period
  pairs                     BitLedger pair reference table
  entry                     Interactive entry (same as bare 'pair')
  status                    System status and pending items
  where <query>             Find entities and entries

Modules:
  asset add|list|show|edit|dispose|amort|writedown|summary
  liability add|list|show|pay|payments|reclassify
  expense add|list
  income add                Non-operating income
  transfer                  Asset-to-asset moves
  revenue project|log|invoice|paid|outstanding|status|export|undo|rate|defer|recognize|deferred
  contact add|list|show|edit|remove
  contract add|list|show|edit
  payroll run|list
  equity invest|draw|convert
  division list             Show divisions with counts
  tax summary|remit
  recurring add|list|generate
  budget set|vs
  year new|close

Global flags:
  --help          Show help for any command
  --yes           Skip confirmations
  --batch         Fully non-interactive
  --dry-run       Preview without writing
  --date DATE     Override today's date (YYYY-MM-DD)

Use 'pair <command> --help' for details.
""")


if __name__ == '__main__':
    main()
